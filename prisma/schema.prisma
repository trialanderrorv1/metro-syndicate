generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CrewRole {
  BOSS
  UNDERBOSS
  CAPTAIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum NotificationKind {
  SYSTEM
  INVITE
  CHAT
  MARKET
  CONTRACT
  TERRITORY
}

model Player {
  id            String         @id @default(cuid())
  handle        String         @unique
  passwordHash  String
  crewId        String?
  stateJson     Json
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
}

model Crew {
  id        String   @id @default(cuid())
  name      String   @unique
  tag       String?
  ownerId   String   @unique
  cash      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CrewInvite {
  id           String       @id @default(cuid())
  crewId       String
  fromPlayerId String
  toPlayerId   String
  status       InviteStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model DirectMessage {
  id           String   @id @default(cuid())
  fromPlayerId String
  toPlayerId   String
  body         String
  createdAt    DateTime @default(now())
}

model MarketListing {
  id        String   @id @default(cuid())
  playerId  String
  itemId    String
  quantity  Int
  unitPrice Int
  status    String   @default("ACTIVE")
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContractMission {
  id            String   @id @default(cuid())
  title         String
  body          String
  rewardCash    Int
  rewardItemId  String?
  rewardRespect Int
  expiresAt     DateTime
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
}

model Territory {
  id         String             @id @default(cuid())
  slug       String             @unique
  name       String
  cityId     String
  baseIncome Int
  createdAt  DateTime           @default(now())
  controls   TerritoryControl[]
}

model TerritoryControl {
  id            String    @id @default(cuid())
  territoryId   String    @unique
  crewId        String?
  crewName      String?
  defense       Int       @default(0)
  passiveIncome Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  territory     Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String           @id @default(cuid())
  playerId   String
  kind       NotificationKind
  title      String
  body       String
  readAt     DateTime?
  detailJson Json?
  createdAt  DateTime         @default(now())
  player     Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
}

model UserAccount {
  id            String         @id @default(cuid())
  handle        String         @unique
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      UserSession[]
  premiumGrants PremiumGrant[]
  auditEvents   AuditEvent[]
}

model UserSession {
  id           String      @id @default(cuid())
  userId       String
  sessionToken String      @unique
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  user         UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PremiumGrant {
  id           String      @id @default(cuid())
  userId       String
  provider     String
  providerRef  String?
  planCode     String
  status       String
  grantedCoins Int         @default(0)
  premiumUntil DateTime
  autoRenew    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  user         UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id            String       @id @default(cuid())
  actorId       String?
  action        String
  targetId      String?
  ipAddress     String?
  metadata      Json?
  createdAt     DateTime     @default(now())
  userAccount   UserAccount? @relation(fields: [userAccountId], references: [id])
  userAccountId String?
}
